#required for coinbase use
#exchange-connector
COINBASEKEY=
COINBASESECRET=

# common
COMPOSE_BAKE=true
COMPOSE_PROJECT_NAME=gainium-app
MONGO_DB_USERNAME=user
MONGO_DB_PASSWORD=password
MONGO_DB_NAME=gainium
MONGO_DB_PORT=27017
MONGO_DB_HOST=mongo
REDIS_PASSWORD=H2Ga1DB1alBg
REDIS_HOST=redis
RABBIT_HOST=rabbit
RABBIT_USER=gainium
RABBIT_PASSWORD=bdo3nyVMX5l6
RABBIT_PORT=5672
EXCHANGE_SERVICE_API_URL=http://exchange-connector
#websocket-connector
PAPER_WS=ws://paper-trading
# NOTE: the price connector is pinned to the "all" role in docker-compose.yml
# (produces candle streams AND the trade@ ticker feed paper-trading fills from).
# This value is vestigial and no longer changes the feed; leave it as-is.
PRICEROLE=all
# Seed list for the admin-config-managed enabled exchanges. admin-sh
# expands these family tokens into per-variant entries the first time
# it boots (e.g. `binance` → binance, binanceCoinm, binanceUsdm). After
# that, the operator manages the list from the dashboard's Admin →
# Exchanges tab — this env value stops being consulted.
PRICE_CONNECTOR_EXCHANGES=binance,binanceus,kucoin,bybit,okx,bitget,coinbase
#main-app
GRAPH_QL_PORT=7503
WS_PORT=7502
BACKTEST_PORT=7515
JWT_SECRET=n3vQzM3OZt0I
PAPER_TRADING_API_URL=http://paper-trading
SERVER_HOST=http://localhost:7503
MAIN_SERVICE_HOST=api
BACKTEST_SERVICE_HOST=backtest
CORS_ORIGIN=http://localhost:7500
#dash
PORT=7500
NEXT_PUBLIC_SERVER=http://localhost:7503
NEXT_PUBLIC_WS=ws://localhost:7502
VITE_ADMIN_API_URL=http://localhost:7507

#admin-sh
# Set to false to disable the Redis-backed admin-config feature across
# the connectors and api. Default is "true" in the compose file — flip
# this to "false" if you'd rather pin everything via env only.
ADMIN_CONFIG_ENABLED=true
ADMIN_PORT=7507
# HOST absolute path of this docker-sh checkout. Required only for the
# self-upgrade flow (the admin UI's "Upgrade" button on the admin-sh
# row). admin-sh spawns a docker:27-cli helper that bind-mounts this
# path to run `docker compose up -d admin-sh` from outside its own
# container lifecycle. Leave blank to disable self-upgrade.
COMPOSE_DIR_HOST_PATH=
# Registry credentials for tag-list lookups. Leave blank for public
# registries (docker.gainium.io's gainium namespace is public).
DOCKER_REGISTRY_HOST=docker.gainium.io
DOCKER_REGISTRY_USER=
DOCKER_REGISTRY_PASS=

# Per-service image version pins. Override to force a specific version
# instead of the compose default. admin-sh writes here when you Upgrade
# from the dashboard, so anything set manually here gets replaced.
# MAIN_APP_VERSION=1.18.0
# EXCHANGE_CONNECTOR_VERSION=1.5.0
# WEBSOCKET_CONNECTOR_VERSION=1.8.0
# PAPER_TRADING_VERSION=1.2.3
# FRONTEND_VERSION=2.5.1
# ADMIN_SH_VERSION=1.0.0
